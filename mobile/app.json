{
  "expo": {
    "name": "Avyuktha Fashions",
    "slug": "avyuktha-fashions",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "avyuktha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FFF9F5",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.avyuktha.fashions"
    },
    "android": {
      "package": "com.avyuktha.fashions",
      "adaptiveIcon": {
        "backgroundColor": "#FFF9F5"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:5000/api/v1"
    }
  }
}
